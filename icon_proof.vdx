<?xml version='1.0' encoding='UTF-8'?>
<VisioDocument xmlns='http://schemas.microsoft.com/visio/2003/core'>
  <Pages>
    <Page ID='0' Name='IconProof'>
      <PageSheet><Cell N='PageWidth' V='5'/><Cell N='PageHeight' V='5'/></PageSheet>
      <Shapes>
        <Shape ID='1' Type='Foreign'>
          <Cell N='PinX' V='2.5'/><Cell N='PinY' V='3'/>
          <Cell N='Width' V='1.5'/><Cell N='Height' V='1.5'/>
          <Cell N='LocPinX' V='0.75'/><Cell N='LocPinY' V='0.75'/>
          <Cell N='ImgWidth' V='1.5'/><Cell N='ImgHeight' V='1.5'/>
          <Cell N='ImgOffsetX' V='0'/><Cell N='ImgOffsetY' V='0'/>
          <ForeignData ForeignType='Bitmap' CompressionType='PNG' CompressionLevel='0' ObjectWidth='256' ObjectHeight='256'></ForeignData>
        </Shape>
        <Shape ID='2' Type='Shape'>
          <Cell N='PinX' V='2.5'/><Cell N='PinY' V='1.2'/>
          <Cell N='Width' V='4.2'/><Cell N='Height' V='0.6'/>
          <Cell N='FillForegnd' V='#eef3fb'/><Cell N='LineColor' V='#3b5b92'/>
          <Text>If the AWS icon shows above, embedded icons work in your Visio.</Text>
          <Geom IX='0'><MoveTo IX='1' X='0' Y='0'/><LineTo IX='2' X='4.2' Y='0'/><LineTo IX='3' X='4.2' Y='0.6'/><LineTo IX='4' X='0' Y='0.6'/><LineTo IX='5' X='0' Y='0'/></Geom>
        </Shape>
      </Shapes>
    </Page>
  </Pages>
</VisioDocument>